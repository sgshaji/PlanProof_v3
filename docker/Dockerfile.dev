# Development container for PlanProof
# WHY: ARM64 Windows cannot build shapely/pymupdf natively.
# This container provides a linux/amd64 environment where all deps install cleanly.

FROM python:3.11-slim

# System dependencies for native extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgeos-dev \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (layer caching — only rebuilds when pyproject.toml changes)
COPY pyproject.toml .
COPY src/planproof/__init__.py src/planproof/__init__.py
RUN pip install --no-cache-dir -e ".[dev]"

# Copy the rest of the source (this layer changes often, but deps are cached above)
COPY . .

# Re-install in editable mode so the package reflects the full source
RUN pip install --no-cache-dir -e ".[dev]"

# Keep container alive for VS Code Dev Container attachment
CMD ["sleep", "infinity"]
