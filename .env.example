# ============================================================================
# PlanProof Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is gitignored — your secrets stay local.
# See docs/CONFIGURATION.md for full documentation.
# ============================================================================

# --- LLM Provider ---
# Options:
#   groq    — Free tier (30 RPM). Get key: https://console.groq.com
#   openai  — Paid (~$2.50/M tokens). Get key: https://platform.openai.com
#   ollama  — Free, runs locally. Install: https://ollama.ai (optional fallback)
#
PLANPROOF_LLM_PROVIDER=groq
PLANPROOF_LLM_MODEL=llama-3.1-70b-versatile

# API key — required for groq and openai
PLANPROOF_LLM_API_KEY=your-groq-api-key-here

# Ollama connection (only if using ollama provider locally)
# PLANPROOF_OLLAMA_BASE_URL=http://localhost:11434

# --- VLM Provider (for architectural drawing analysis) ---
# PLANPROOF_VLM_PROVIDER=openai
# PLANPROOF_VLM_MODEL=gpt-4o

# --- Neo4j Aura (free cloud instance) ---
# Sign up: https://aura.neo4j.io
# Create a free instance and paste your credentials below.
PLANPROOF_NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
PLANPROOF_NEO4J_USER=neo4j
PLANPROOF_NEO4J_PASSWORD=your-aura-password-here
