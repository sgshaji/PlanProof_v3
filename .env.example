# ============================================================================
# PlanProof Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is gitignored — your secrets stay local.
# See docs/CONFIGURATION.md for full documentation.
# ============================================================================

# --- LLM Provider ---
# Choose your LLM provider. Default is Ollama (free, no API key needed).
#
# Options:
#   ollama  — Free, runs locally. No API key. Install: https://ollama.ai
#   groq    — Free tier (30 RPM). Get key: https://console.groq.com
#   openai  — Paid (~$2.50/M tokens). Get key: https://platform.openai.com
#
PLANPROOF_LLM_PROVIDER=ollama
PLANPROOF_LLM_MODEL=llama3.1

# API key — only needed for groq or openai (leave empty for ollama)
PLANPROOF_LLM_API_KEY=

# Ollama connection (only if using ollama provider)
# Default works with Docker Compose. Change if running Ollama elsewhere.
# PLANPROOF_OLLAMA_BASE_URL=http://localhost:11434

# --- VLM Provider (for architectural drawing analysis) ---
# PLANPROOF_VLM_PROVIDER=ollama
# PLANPROOF_VLM_MODEL=llava

# --- Neo4j (optional — defaults work with Docker Compose) ---
# PLANPROOF_NEO4J_URI=bolt://localhost:7687
# PLANPROOF_NEO4J_USER=neo4j
# PLANPROOF_NEO4J_PASSWORD=planproof-dev
